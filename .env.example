# HEU Admission CRM local environment template.
# Copy keys into .env.local on the machine/server that runs the app.
# Do not commit .env.local and do not paste secret values into chat, tickets or logs.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only key. Required for in-app automatic user creation.
# Keep this empty in committed examples.
SUPABASE_SERVICE_ROLE_KEY=
